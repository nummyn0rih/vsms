# Скопируй в .env и заполни значениями (см. README/CLAUDE.md).

# PostgreSQL (Neon). Пулерное подключение для рантайма.
DATABASE_URL=
# Прямое подключение к БД (для prisma migrate/studio при пулере Neon).
DIRECT_URL=

# Auth.js v5 (читает префикс AUTH_, не NEXTAUTH_).
# Сгенерировать секрет: `npx auth secret` или `openssl rand -base64 32`
AUTH_SECRET=
# AUTH_URL в dev необязателен (автоопределение). Задать при деплое за прокси.
AUTH_URL=http://localhost:3000

# Сид первого admin (только для запуска `npm run db:seed`, не для рантайма).
# Лучше передавать инлайн в команде, а не хранить пароль в файле.
SEED_ADMIN_LOGIN=
SEED_ADMIN_PASSWORD=
