# Скопируй в .env и заполни значениями (см. README/CLAUDE.md).

# PostgreSQL (Neon). Пулерное подключение для рантайма.
DATABASE_URL=
# Прямое подключение к БД (для prisma migrate/studio при пулере Neon).
DIRECT_URL=

# Auth.js (NextAuth)
# Сгенерировать секрет: `npx auth secret` или `openssl rand -base64 32`
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
